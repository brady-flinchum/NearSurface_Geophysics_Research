@article{Kelly1989, 
	year     = {1989}, 
	title    = {Mass and chemical composition of roots in two second-growth oak forests in Eastern Tennessee}, 
	author   = {Kelly, J.M. and Joslin, J.D.}, 
	journal  = {Forest Ecology and Management}, 
	issn     = {0378-1127}, 
	doi      = {10.1016/0378-1127(89)90030-3}, 
	abstract = {Root mass and chemistry were evaluated at two similar deciduous forest sites (Camp Branch and Cross Creek) in the Cumberland Plateau region of Tennessee. Soil cores to a depth of 50 cm at 10 intervals during a 12-month period were collected using a 10-cm diameter, power-driven sampling tube. Samples were divided into three layers (0–10, 10–30, and 30–50 cm) and the roots extracted, cleaned, and oven-dried, weighed, ashed, and analyzed for N, P, K, Mg, and S. Since no statistically significant (P = 0.05) fluctuations in root mass or chemistry were observed across the 10 sampling dates within a site, all data were combined for statistical analysis and means calculation. Mean root biomass for the upper 50 cm of soil profile was 39.0 and 33.4 t ha−1 at Camp Branch and Cross Creek, respectively. Concentrations of N, P, K, Ca, Mg, and S showed considerable variation with depth. Root, N, S, and P concentrations were greatest in the surface layer at both sites, while cations followed no consistent patterns with depth.}, 
	pages    = {87--92}, 
	number   = {2}, 
	volume   = {27}
}
@article{Millikin1999, 
	year     = {1999}, 
	title    = {Biomass and distribution of fine and coarse roots from blue oak (Quercus douglasii) trees in the northern Sierra Nevada foothills of California}, 
	author   = {Millikin, Catherine S. and Bledsoe, Caroline S.}, 
	journal  = {Plant and Soil}, 
	issn     = {0032-079X}, 
	doi      = {10.1023/a:1004653932675}, 
	abstract = {This research adds to the limited data on coarse and fine root biomass for blue oak (Quercus douglasii Hook and Arn.), a California deciduous oak species found extensively throughout the interior foothills surrounding the Central Valley. Root systems of six blue oak trees were analyzed using three methods — backhoe excavation, quantitative pits, and soil cores. Coarse root biomass ranged from 7 to 177 kg per tree. Rooting depth for the main root system ranged from 0.5 to 1.5 m, with an average of 70\% of excavated root biomass located above 0.5 m. Of the total biomass in excavated central root systems, primary roots (including burls) accounted for 56\% and large lateral roots (> 20 mm diameter) accounted for 36\%. Data from cores indicated that most biomass outside of the root crown was located in fine roots and that fine root biomass decreased with depth. At surface depths (0–20 cm), small-fine (< 0.5 mm diameter) roots accounted for 71\%, large-fine (0.5–2.0 mm) for 25\%, and coarse (> 2 mm) for 4\% of total root biomass collected with cores. Mean fine root biomass density in the top 50 cm was 0.43 kg m−3. Fine root biomass did not change with increasing distance from the trees (up to approximately 5 m). Thus, fine roots were not concentrated under the tree canopies. Our results emphasize the importance of the smallest size class of roots (<0.5 mm), which had both higher N concentration and, in the area outside the central root system, greater biomass than large fine (0.5–2.0 mm) or coarse (> 2.0 mm) roots.}, 
	pages    = {27--38}, 
	number   = {1-2}, 
	volume   = {214}
}
