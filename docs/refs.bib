	issn     = {1070-485X}, 
	doi      = {10.1190/tle39050332.1}, 
	abstract = {{GPRPy} is an open-source ground-penetrating radar software compatible with a range of ground-penetrating radar systems. Data processing and plotting can be performed by using graphical user interfaces or scripts that are generated automatically from the graphical user interfaces. This makes learning the software easy, and it enables researchers to share their scripts as part of a publication to ensure reproducible research. {GPRPy} enables profile data processing and visualization, velocity analysis, interpolation of 3D data cubes from profile data, and 3D interpolation for interfaces visible in multiple profiles. The software is written in Python and runs on all major operating systems.}, 
	pages    = {332--337}, 
